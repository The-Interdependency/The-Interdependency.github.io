{
  "name": "interdependent-way-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf _site .pagefind",
    "build": "eleventy",
    "postbuild": "pagefind --site _site --output-path _site/pagefind",
    "serve": "eleventy --serve --port 8080",
    "lint:links": "linkinator _site --recurse --silent --skip '.*(localhost|127.0.0.1).*' || true"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@pagefind/cli": "^1.1.0",
    "linkinator": "^4.0.0",
    "markdown-it": "^14.1.0",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
